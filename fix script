function processFiles() {
    const obsFile = document.getElementById("obsFile").files[0];
    const csvFile = document.getElementById("csvFile").files[0];

    if (!obsFile || !csvFile) {
        alert("Please upload both files.");
        return;
    }

    const obsReader = new FileReader();
    const csvReader = new FileReader();

    obsReader.onload = function (obsEvent) {
        csvReader.onload = function (csvEvent) {
            try {
                const obsData = JSON.parse(obsEvent.target.result);
                const csvText = csvEvent.target.result;

                const lotNames = buildLotNamesFromCSV(csvText);

                if (!lotNames.length) {
                    alert("No lot names found in CSV.");
                    return;
                }

                const renamePairs = [];
                const lotSceneIndexes = [];

                for (let i = 0; i < obsData.scene_order.length; i++) {
                    const sceneName = obsData.scene_order[i].name;
                    if (isLotScene(sceneName)) {
                        lotSceneIndexes.push(i);
                    }
                }

                let lotIndex = 0;
                let unusedIndex = 1;

                for (let i = 0; i < lotSceneIndexes.length; i += 2) {
                    const transitionIndex = lotSceneIndexes[i];
                    const videoIndex = lotSceneIndexes[i + 1];

                    if (videoIndex === undefined) break;

                    const oldTransition = obsData.scene_order[transitionIndex].name;
                    const oldVideo = obsData.scene_order[videoIndex].name;

                    let newTransition, newVideo;

                    if (lotIndex < lotNames.length) {
                        const base = lotNames[lotIndex];
                        newTransition = `${base} Transition`;
                        newVideo = `${base} Video`;
                        lotIndex++;
                    } else {
                        const padded = String(unusedIndex).padStart(3, "0");
                        newTransition = `UNUSED ${padded} Transition`;
                        newVideo = `UNUSED ${padded} Video`;
                        unusedIndex++;
                    }

                    obsData.scene_order[transitionIndex].name = newTransition;
                    obsData.scene_order[videoIndex].name = newVideo;

                    renamePairs.push([oldTransition, newTransition]);
                    renamePairs.push([oldVideo, newVideo]);
                }

                const renameMap = new Map(renamePairs);

                if (Array.isArray(obsData.sources)) {
                    for (const source of obsData.sources) {
                        if (renameMap.has(source.name)) {
                            source.name = renameMap.get(source.name);
                        }
                    }
                }

                if (typeof obsData.current_scene === "string" && renameMap.has(obsData.current_scene)) {
                    obsData.current_scene = renameMap.get(obsData.current_scene);
                }

                if (typeof obsData.current_program_scene === "string" && renameMap.has(obsData.current_program_scene)) {
                    obsData.current_program_scene = renameMap.get(obsData.current_program_scene);
                }

                downloadJSON(obsData, "updated_scene_collection.json");
            } catch (error) {
                console.error(error);
                alert("Something went wrong. If it fails again, send me a screenshot of the error in the browser console.");
            }
        };

        csvReader.readAsText(csvFile);
    };

    obsReader.readAsText(obsFile);
}

function buildLotNamesFromCSV(csvText) {
    const lines = csvText
        .split(/\r?\n/)
        .filter(line => line.trim() !== "");

    if (lines.length < 2) return [];

    const headers = splitCSVLine(lines[0]).map(h => cleanCell(h));
    const lotIndex = headers.findIndex(h => h.toLowerCase() === "lot number");

    if (lotIndex === -1) {
        throw new Error('Could not find "Lot Number" column.');
    }

    const result = [];

    for (let i = 1; i < lines.length; i++) {
        const cols = splitCSVLine(lines[i]);
        let rawLot = cleanCell(cols[lotIndex] || "");

        if (!rawLot) continue;

        rawLot = normalizeLot(rawLot);
        result.push(rawLot);
    }

    return result;
}

function splitCSVLine(line) {
    const result = [];
    let current = "";
    let inQuotes = false;

    for (let i = 0; i < line.length; i++) {
        const char = line[i];
        const next = line[i + 1];

        if (char === '"') {
            if (inQuotes && next === '"') {
                current += '"';
                i++;
            } else {
                inQuotes = !inQuotes;
            }
        } else if (char === "," && !inQuotes) {
            result.push(current);
            current = "";
        } else {
            current += char;
        }
    }

    result.push(current);
    return result;
}

function cleanCell(value) {
    return String(value).trim().replace(/^"|"$/g, "");
}

function normalizeLot(rawLot) {
    const lot = rawLot.replace(/\s+/g, "").toUpperCase();

    const match = lot.match(/^(\d+)([A-Z])$/);
    if (match) {
        return `${match[1]}-${match[2]}`;
    }

    return lot;
}

function isLotScene(name) {
    const cleaned = String(name).replace(/\s+/g, " ").trim();
    return /^\d+(-[A-Z])? (Transition|Video)$/.test(cleaned);
}

function downloadJSON(data, filename) {
    const blob = new Blob([JSON.stringify(data, null, 2)], {
        type: "application/json"
    });

    const url = URL.createObjectURL(blob);
    const link = document.getElementById("downloadLink");

    link.href = url;
    link.download = filename;
    link.style.display = "inline-block";
    link.innerText = "Download Updated OBS File";
}
